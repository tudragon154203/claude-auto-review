{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Delete|Remove|Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "python -m claude_auto_review.hooks.post_tool_use",
            "timeout": 10,
            "statusMessage": "Claude Auto Review: tracking changed file..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m claude_auto_review.hooks.stop_hook",
            "timeout": 660,
            "statusMessage": "Claude Auto Review: checking review state..."
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -m claude_auto_review.hooks.session_end",
            "timeout": 10,
            "statusMessage": "Claude Auto Review: cleaning session state..."
          }
        ]
      }
    ]
  }
}
