{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Delete|Remove",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/post_tool_use.py",
            "timeout": 10,
            "statusMessage": "Claude Auto Review: tracking changed file..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/stop_hook.py",
            "timeout": 30,
            "statusMessage": "Claude Auto Review: checking review state..."
          }
        ]
      }
    ],
    "SessionStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/session_stop.py",
            "timeout": 10,
            "statusMessage": "Claude Auto Review: cleaning session state..."
          }
        ]
      }
    ]
  }
}
